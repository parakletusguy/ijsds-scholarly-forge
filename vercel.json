{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/robots.txt"
    },
    {
      "source": "/feed/latest-articles.xml",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/feed/latest-articles.xml"
    },
    {
      "source": "/papers",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/papers"
    },
    {
      "source": "/papers/:id",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/papers/:id"
    },
    {
      "source": "/article/:slug",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/article/:slug"
    },
    {
      "source": "/articles/:slug",
      "destination": "https://ijsdsbackend-429660256945.europe-southwest1.run.app/articles/:slug"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}